---
import { setupCustomSelects } from './dropdown-select';

interface Option {
  label: string;
  i18nKey?: string;
}

interface Props {
  id: string;
  name: string;
  options: (string | Option)[];
  placeholder?: string;
  required?: boolean;
}

const { id, name, options, placeholder = "Selecciona una opción", required = false } = Astro.props;

// Normalizar opciones para que todas sean objetos
const normalizedOptions = options.map(opt => 
  typeof opt === 'string' ? { label: opt } : opt
);
---

<div class="custom-select-wrapper" id={`wrapper-${id}`}>
  <div class="custom-select">
    <div class="custom-select__trigger">
      <span class="trigger-text" data-i18n-key="quoteForm.selectPlaceholder">{placeholder}</span>
      <div class="arrow"></div>
    </div>
    <div class="custom-options">
      {normalizedOptions.map((option) => (
        <span class="custom-option" data-value={option.label} data-i18n-key={option.i18nKey}>
          {option.label}
        </span>
      ))}
    </div>
  </div>
  <select {id} {name} {required} style="display: none;">
    <option value="" disabled selected>{placeholder}</option>
    {normalizedOptions.map((option) => (
      <option value={option.label}>{option.label}</option>
    ))}
  </select>
</div>

<style>
  /* Custom Select Styles */
  .custom-select-wrapper {
    position: relative;
    user-select: none;
    width: 100%;
    font-family: "Inter", sans-serif;
  }

  .custom-select {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .custom-select__trigger {
    padding: 14px 16px;
    border: 1.5px solid #d1d5db;
    border-radius: 12px;
    font-size: 15px;
    background: #ffffff;
    color: #61758A;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.2s ease;
  }

  .custom-select.open .custom-select__trigger {
    border-color: #005DAA;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
  }

  .custom-select__trigger .arrow {
    width: 10px;
    height: 10px;
    border-right: 2px solid #61758A;
    border-bottom: 2px solid #61758A;
    transform: rotate(45deg);
    transition: transform 0.2s ease;
    margin-right: 5px;
    margin-top: -2px;
  }

  .custom-select.open .arrow {
    transform: rotate(225deg);
    margin-top: 5px;
  }

  .custom-options {
    position: absolute;
    display: block;
    top: 100%;
    left: 0;
    right: 0;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    background: #fff;
    transition: all 0.2s ease;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-10px);
    z-index: 100;
    margin-top: 8px;
    padding: 6px;
    max-height: 250px;
    overflow-y: auto;
  }

  .custom-select.open .custom-options {
    opacity: 1;
    visibility: visible;
    pointer-events: all;
    transform: translateY(0);
  }

  .custom-option {
    position: relative;
    display: block;
    padding: 10px 14px;
    font-size: 15px;
    font-weight: 500;
    color: #1e293b;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 8px;
  }

  .custom-option:hover {
    background-color: #005DAA;
    color: #ffffff;
  }

  .custom-option.selected {
    background-color: #f1f5f9;
    color: #1e293b;
    font-weight: 600;
  }

  .custom-option.selected:hover {
    background-color: #005DAA;
    color: #ffffff;
  }
</style>

<script>
  import { setupCustomSelects } from './dropdown-select';
  setupCustomSelects();
</script>