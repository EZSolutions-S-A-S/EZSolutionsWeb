<div id="quote-overlay" class="quote-overlay">
  <div class="quote-modal" role="dialog" aria-modal="true">
    
    <div class="quote-modal-header">

      <div class="quote-modal-title">
        <h2>Cotizar Proyecto</h2>
        <p class="quote-subtitle">
          Cuéntanos sobre tu proyecto y te contactaremos pronto.
        </p>
      </div>

      <button id="quote-close-btn" class="quote-close-btn" aria-label="Cerrar modal">
        ✕
      </button>

    </div>

    <div class="quote-modal-body">
        <div id="form-alert" class="form-alert">
  <div class="form-alert-content">
    <span class="form-alert-icon">⚠</span>
    <span id="form-alert-text"></span>
  </div>
</div>

      <form id="quote-form" class="quote-form" novalidate>

        <div class="quote-form-grid">

          <div class="quote-form-group">
            <label>
                Nombre completo <span class="quote-required">*</span>
            </label>
            <input type="text" placeholder="Tu nombre" required />
          </div>

          <div class="quote-form-group">
            <label>
                Correo electrónico <span class="quote-required">*</span>
            </label>
            <input type="email" placeholder="tu@email.com" required />
          </div>

          <div class="quote-form-group">
            <label>
                Empresa <span class="quote-optional">(opcional)</span>
            </label>
            <input type="text" placeholder="Nombre de tu empresa" />
          </div>

          <div class="quote-form-group">
            <label>
              Tipo de proyecto <span class="quote-required">*</span>
            </label>
            <div class="custom-select-wrapper">
              <div class="custom-select">
                <div class="custom-select__trigger">
                  <span>Selecciona una opción</span>
                  <div class="arrow"></div>
                </div>
                <div class="custom-options">
                  <span class="custom-option selected" data-value="Software a la medida">Software a la medida</span>
                  <span class="custom-option" data-value="Sistema de inventario">Sistema de inventario</span>
                  <span class="custom-option" data-value="Sistema de ventas">Sistema de ventas</span>
                  <span class="custom-option" data-value="Aplicación web">Aplicación web</span>
                  <span class="custom-option" data-value="Aplicación móvil">Aplicación móvil</span>
                  <span class="custom-option" data-value="Otro">Otro</span>
                </div>
              </div>
              <select required id="project-type-select" name="project_type" style="display: none;">
                <option value="" disabled selected>Selecciona una opción</option>
                <option value="Software a la medida">Software a la medida</option>
                <option value="Sistema de inventario">Sistema de inventario</option>
                <option value="Sistema de ventas">Sistema de ventas</option>
                <option value="Aplicación web">Aplicación web</option>
                <option value="Aplicación móvil">Aplicación móvil</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
          </div>

        </div>

        <div class="quote-form-group quote-full">
          <label>
            Descripción del proyecto <span class="quote-required">*</span>
          </label>
          <textarea
            rows="5"
            placeholder="Cuéntanos sobre tu proyecto, objetivos y necesidades"
            required></textarea>
        </div>

        <div class="quote-form-group quote-full">
          <label>
            Presupuesto estimado <span class="quote-optional">(opcional)</span>
        </label>
          <input type="text" placeholder="Ej: $1.500.000 - $3.000.000 COP" />
        </div>

        <button type="submit" class="quote-submit-btn">
          Enviar Solicitud
        </button>

      </form>

    </div>
  </div>
</div>

<script src="./quote-modal.js"></script>