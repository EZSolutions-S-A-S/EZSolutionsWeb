---
import CustomSelect from '../../inputs/dropdown_select.astro';
---
<div id="quote-overlay" class="quote-overlay">
  <div class="quote-modal" role="dialog" aria-modal="true">
    
    <!-- Loading Screen -->
    <div id="quote-loading" class="quote-loading">
      <div class="quote-loading-content">
        <div class="quote-spinner"></div>
        <p class="quote-loading-text" data-i18n-key="quoteForm.sending">Enviando tu cotización...</p>
      </div>
    </div>

    <!-- Success Screen -->
    <div id="quote-success" class="quote-success">
      <div class="quote-success-content">
        <div class="quote-success-icon">✓</div>
        <h2 class="quote-success-title" data-i18n-key="quoteForm.successTitle">¡Cotización Enviada!</h2>
        <p class="quote-success-message" data-i18n-key="quoteForm.successMessage">Gracias por tu interés. Nos pondremos en contacto muy pronto.</p>
        <div class="quote-success-footer">
          <p class="quote-success-close" data-i18n-key="quoteForm.closingModal">Cerrando...</p>
        </div>
      </div>
    </div>
    
    <div class="quote-modal-header">

      <div class="quote-modal-title">
        <h2 data-i18n-key="quoteForm.title">Cotizar Proyecto</h2>
        <p class="quote-subtitle" data-i18n-key="quoteForm.subtitle">
          Cuéntanos sobre tu proyecto y te contactaremos pronto.
        </p>
      </div>

      <button id="quote-close-btn" class="quote-close-btn" aria-label="Cerrar modal" data-i18n-attr='{"aria-label": "quoteForm.closeBtn"}'>
        ✕
      </button>

    </div>

    <div class="quote-modal-body">
        <div id="form-alert" class="form-alert">
  <div class="form-alert-content">
    <span class="form-alert-icon">⚠</span>
    <span id="form-alert-text"></span>
  </div>
</div>

      <form id="quote-form" class="quote-form" novalidate>

        <div class="quote-form-grid">

          <div class="quote-form-group">
            <label for="quote-name">
                <span data-i18n-key="quoteForm.nameLabel">Nombre completo</span> <span class="quote-required" data-i18n-key="quoteForm.required">*</span>
            </label>
            <input id="quote-name" name="name" type="text" placeholder="Tu nombre" data-i18n-attr='{"placeholder": "quoteForm.namePlaceholder"}' required />
          </div>

          <div class="quote-form-group">
            <label for="quote-email">
                <span data-i18n-key="quoteForm.emailLabel">Correo electrónico</span> <span class="quote-required" data-i18n-key="quoteForm.required">*</span>
            </label>
            <input id="quote-email" name="email" type="email" placeholder="tu@email.com" data-i18n-attr='{"placeholder": "quoteForm.emailPlaceholder"}' required />
          </div>

          <div class="quote-form-group">
            <label for="quote-phone">
                <span data-i18n-key="quoteForm.phoneLabel">Teléfono</span> <span class="quote-required" data-i18n-key="quoteForm.required">*</span>
            </label>
            <input id="quote-phone" name="phone" type="tel" placeholder="Tu número de teléfono" data-i18n-attr='{"placeholder": "quoteForm.phonePlaceholder"}' required />
          </div>

          <div class="quote-form-group">
            <label for="quote-company">
                <span data-i18n-key="quoteForm.companyLabel">Empresa</span> <span class="quote-optional" data-i18n-key="quoteForm.optional">(opcional)</span>
            </label>
            <input id="quote-company" name="company" type="text" placeholder="Nombre de tu empresa" data-i18n-attr='{"placeholder": "quoteForm.companyPlaceholder"}' />
          </div>

          <div class="quote-form-group">
            <label for="project-type-select">
              <span data-i18n-key="quoteForm.projectTypeLabel">Tipo de proyecto</span> <span class="quote-required" data-i18n-key="quoteForm.required">*</span>
            </label>
            <CustomSelect 
              id="project-type-select" 
              name="project_type" 
              required={true}
              options={[
                { label: "Software a la medida", i18nKey: "quoteForm.projectTypeOption1" },
                { label: "Sistema de inventario", i18nKey: "quoteForm.projectTypeOption2" },
                { label: "Sistema de ventas", i18nKey: "quoteForm.projectTypeOption3" },
                { label: "Aplicación web", i18nKey: "quoteForm.projectTypeOption4" },
                { label: "Aplicación móvil", i18nKey: "quoteForm.projectTypeOption5" },
                { label: "Otro", i18nKey: "quoteForm.projectTypeOption6" }
              ]}
            />
          </div>

        </div>

        <div class="quote-form-group quote-full">
          <label for="quote-description">
            <span data-i18n-key="quoteForm.descriptionLabel">Descripción del proyecto</span> <span class="quote-required" data-i18n-key="quoteForm.required">*</span>
          </label>
          <textarea
            id="quote-description"
            name="description"
            rows="5"
            placeholder="Cuéntanos sobre tu proyecto, objetivos y necesidades"
            data-i18n-attr='{"placeholder": "quoteForm.descriptionPlaceholder"}'
            required></textarea>
        </div>

        <div class="quote-form-group quote-full">
          <label for="quote-budget">
            <span data-i18n-key="quoteForm.budgetLabel">Presupuesto estimado</span> <span class="quote-optional" data-i18n-key="quoteForm.optional">(opcional)</span>
          </label>
          <input id="quote-budget" name="budget" type="text" placeholder="Ej: $1.500.000 - $3.000.000 COP" data-i18n-attr='{"placeholder": "quoteForm.budgetPlaceholder"}' />
        </div>

        <!-- Honeypot field: hidden from real users, filled by spam bots -->
        <input id="quote-website" name="website" type="text" style="display: none; position: absolute; left: -9999px;" tabindex="-1" autocomplete="off" />

        <button type="submit" class="quote-submit-btn" data-i18n-key="quoteForm.submitBtn">
          Enviar Solicitud
        </button>

      </form>

    </div>
  </div>
</div>

<script>
  import "./quote-modal.js";
</script>