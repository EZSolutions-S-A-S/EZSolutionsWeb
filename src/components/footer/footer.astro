---
import facebookIcon from '@/components/footer/icons_footer/facebook.svg';
import instagramIcon from '@/components/footer/icons_footer/instagram.svg';
import linkedinIcon from '@/assets/icons/linkedin.svg';
import tiktokIcon from '@/components/footer/icons_footer/tiktok.svg';
import logoWhite from '@/assets/icons/logo-ezsolutions-white.svg';
---

<footer class="site-footer">
  <div class="footer-container">

    <div class="footer-left">

      <div class="footer-brand">
        <img 
          src={logoWhite.src}
          alt="EZSolutions Logo" 
          class="footer-logo"
        />

        <p class="footer-description" data-i18n-key="footer.description">
          Transformamos ideas en soluciones digitales. Software a la medida para impulsar tu negocio.        </p>

        <div class="social-icons">
          <a href="https://facebook.com" target="_blank" rel="noopener noreferrer">
            <img src={facebookIcon.src} alt="Facebook" />
          </a>
          <a href="https://instagram.com" target="_blank" rel="noopener noreferrer">
            <img src={instagramIcon.src} alt="Instagram" />
          </a>
          <a href="https://www.linkedin.com/company/ezsolutionssas/" target="_blank" rel="noopener noreferrer">
            <img src={linkedinIcon.src} alt="LinkedIn" />
          </a>
          <a href="https://tiktok.com" target="_blank" rel="noopener noreferrer">
            <img src={tiktokIcon.src} alt="TikTok" />
          </a>
        </div>
      </div>

      <div class="footer-column">
        <h4 data-i18n-key="footer.company">Empresa</h4>
        <a href="/#nosotros" data-i18n-key="footer.about">Nosotros</a>
        <a href="/#tecnologias" data-i18n-key="footer.technologies">Tecnologías</a>
        <a href="/#contacto" data-i18n-key="footer.contact">Contacto</a>
      </div>

    </div>

    <div class="footer-right">

      <div class="footer-column">
        <h4 data-i18n-key="footer.services">Servicios</h4>
        <a href="/#servicios" data-i18n-key="footer.custom">Software a la Medida</a>
        <a href="/#servicios" data-i18n-key="footer.inventory">Sistemas de Inventario</a>
        <a href="/#servicios" data-i18n-key="footer.sales">Sistemas de Ventas</a>
        <a href="/#servicios" data-i18n-key="footer.apps">Apps Móviles</a>
      </div>

      <div class="footer-column">
        <h4 data-i18n-key="footer.legal">Legal</h4>
        <a href="#" id="privacy-link" data-i18n-key="footer.privacy">Política de Privacidad</a>
        <a href="#" id="terms-link" data-i18n-key="footer.terms">Términos de Servicio</a>
      </div>

    </div>

  </div>

  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <div>
        <p data-i18n-key="footer.copyright">© 2026 EZsolutions S.A.S. Todos los derechos reservados.</p>
        <p data-i18n-key="footer.location">Quindío, Colombia</p>
      </div>
      <div class="footer-lang-selector">
        <button data-lang-switch="es" class="lang-btn" onclick="switchLanguage('es')">ES</button>
        <span>|</span>
        <button data-lang-switch="en" class="lang-btn" onclick="switchLanguage('en')">EN</button>
      </div>
    </div>
  </div>
</footer>

<script>
  import { setLanguage } from '../../i18n/i18n-client';
  
  (window as any).switchLanguage = (lang: string) => {
    setLanguage(lang as 'es' | 'en');
  };
</script>
