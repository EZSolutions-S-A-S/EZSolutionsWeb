
---
const technologies = [
  { name: "Java", icon: "src/sections/technologies/icons_technologies/java.svg" },
  { name: "JavaScript", icon: "src/sections/technologies/icons_technologies/javascript.svg" },
  { name: "Spring Boot", icon: "src/sections/technologies/icons_technologies/spring.svg" },
  { name: "Django", icon: "src/sections/technologies/icons_technologies/django.svg" },
  { name: "Git", icon: "src/sections/technologies/icons_technologies/git.svg" },
  { name: "Flutter", icon: "src/sections/technologies/icons_technologies/flutter.svg" },
  { name: "Docker", icon: "src/sections/technologies/icons_technologies/docker.svg" },
  { name: "Firebase", icon: "src/sections/technologies/icons_technologies/firebase.svg" },
  { name: "Python", icon: "src/sections/technologies/icons_technologies/python.svg" },
];
---

<section class="technologies">

  <img src="src/sections/technologies/icons_technologies/hexagon_white.svg" class="hex hex-top-left" alt="" />
  <img src="src/sections/technologies/icons_technologies/hexagon_white.svg" class="hex hex-bottom-right" alt="" />

  <div class="container">

    <span class="tech-badge">Stack Tecnológico</span>

    <h2 class="tech-title">
      Tecnologías que Dominamos
    </h2>

    <p class="tech-description">
      Ofrecemos una gama completa de servicios de desarrollo de software diseñados para optimizar y digitalizar tu empresa.
    </p>

    <div class="wrapper">
      <!-- Marquee Left (Top) -->
      <div class="marquee marquee--left">
        {Array(2).fill(null).map(() => (
          <div class="marquee__group">
            {technologies.map((tech) => (
              <div class="tech-card">
                <img src={tech.icon} alt={tech.name} />
                <span>{tech.name}</span>
              </div>
            ))}
          </div>
        ))}
      </div>

      <!-- Marquee Right (Bottom) -->
      <div class="marquee marquee--right">
        {Array(2).fill(null).map(() => (
          <div class="marquee__group">
            {technologies.map((tech) => (
              <div class="tech-card">
                <img src={tech.icon} alt={tech.name} />
                <span>{tech.name}</span>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <p class="tech-footer">
      Y muchas más tecnologías adaptadas a las necesidades de cada proyecto
    </p>

  </div>
</section>

<script src="./technology_stack.js"></script>

