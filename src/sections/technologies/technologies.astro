
---
import hexagonIcon from './icons_technologies/hexagon_white.svg';
import javaIcon from './icons_technologies/java.svg';
import jsIcon from './icons_technologies/javascript.svg';
import springIcon from './icons_technologies/spring.svg';
import djangoIcon from './icons_technologies/django.svg';
import gitIcon from './icons_technologies/git.svg';
import flutterIcon from './icons_technologies/flutter.svg';
import dockerIcon from './icons_technologies/docker.svg';
import firebaseIcon from './icons_technologies/firebase.svg';
import pythonIcon from './icons_technologies/python.svg';

const technologies = [
  { name: "Java", icon: javaIcon.src },
  { name: "JavaScript", icon: jsIcon.src },
  { name: "Spring Boot", icon: springIcon.src },
  { name: "Django", icon: djangoIcon.src },
  { name: "Git", icon: gitIcon.src },
  { name: "Flutter", icon: flutterIcon.src },
  { name: "Docker", icon: dockerIcon.src },
  { name: "Firebase", icon: firebaseIcon.src },
  { name: "Python", icon: pythonIcon.src },
];
---

<section class="technologies">

  <img src={hexagonIcon.src} class="hex hex-top-left" alt="" />
  <img src={hexagonIcon.src} class="hex hex-bottom-right" alt="" />

  <div class="container">

    <span class="tech-badge">Stack Tecnológico</span>

    <h2 class="tech-title">
      Tecnologías que Dominamos
    </h2>

    <p class="tech-description">
      Ofrecemos una gama completa de servicios de desarrollo de software diseñados para optimizar y digitalizar tu empresa.
    </p>

    <div class="wrapper">
      <div class="marquee marquee--left">
        {Array(2).fill(null).map(() => (
          <div class="marquee__group">
            {technologies.map((tech) => (
              <div class="tech-card">
                <img src={tech.icon} alt={tech.name} />
                <span>{tech.name}</span>
              </div>
            ))}
          </div>
        ))}
      </div>

      <div class="marquee marquee--right">
        {Array(2).fill(null).map(() => (
          <div class="marquee__group">
            {technologies.map((tech) => (
              <div class="tech-card">
                <img src={tech.icon} alt={tech.name} />
                <span>{tech.name}</span>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    <p class="tech-footer">
      Y muchas más tecnologías adaptadas a las necesidades de cada proyecto
    </p>

  </div>
</section>

<script>
  import "./technology_stack.js";
</script>

