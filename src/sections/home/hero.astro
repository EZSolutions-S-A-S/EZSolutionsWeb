---
import hexagonIcon from '../../assets/icons/hexagon.svg';
---

<section class="hero">
  <div class="container hero-grid">

    <div class="hero-content">
      <span class="badge" data-i18n-key="home.heroBadge">
        Desarrollo de Software a la Medida
      </span>

      <h1>
        <span data-i18n-key="home.heroTitleLine1">Transformamos tus</span> <br />
        <span class="highlight" data-i18n-key="home.heroTitleHighlight"> ideas en soluciones</span><br />
        <span data-i18n-key="home.heroTitleLine2">digitales</span>
      </h1>

      <span class="hero-line"></span>

      <p data-i18n-key="home.heroDescription">
        Creamos software personalizado que impulsa la digitalización de tu
        empresa, optimizando procesos clave como inventario y ventas con
        herramientas accesibles e intuitivas.
      </p>

      <div class="hero-buttons">
        <a href="#" class="btn-primary open-quote-modal" data-i18n-key="home.heroPrimaryButton">
          Iniciar Proyecto →
        </a>

        <a href="/#nosotros" class="btn-outline" data-i18n-key="home.heroSecondaryButton">
          Conocer Más
        </a>
      </div>
    </div>

    <div class="hero-decoration">
  <img src={hexagonIcon.src} class="hex hex-1" alt="" />
  <img src={hexagonIcon.src} class="hex hex-2" alt="" />
  <img src={hexagonIcon.src} class="hex hex-3" alt="" />
  <img src={hexagonIcon.src} class="hex hex-4" alt="" />
  <img src={hexagonIcon.src} class="hex hex-5" alt="" />

  </div>
</section>
