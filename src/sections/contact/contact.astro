---
import locationIcon from './icons_contact/location.svg';
import phoneIcon from './icons_contact/phone.svg';
import emailIcon from './icons_contact/email.svg';
import hexagonIcon from '../../assets/icons/hexagon.svg';
---

<section class="contact-section">
  <div class="contact-container">

    <div class="contact-badge">Contacto</div>

    <h2 class="contact-title">
       ¿Listo para <span class="text-primary">Empezar tu Proyecto? </span> 
    </h2>

    <p class="contact-description">
Cuéntanos sobre tu idea y te ayudaremos a convertirla en realidad. ¡Estamos aquí para ayudarte!    </p>

    <div class="contact-info-grid">

      <div class="contact-card">
        <div class="icon-wrapper">
          <img src={locationIcon.src} alt="Location icon" />
        </div>
        <div class="contact-card-content">
          <h4>Ubicación</h4>
          <p>Quindío, Colombia</p>
        </div>
      </div>

      <div class="contact-card">
        <div class="icon-wrapper">
          <img src={phoneIcon.src} alt="Phone icon" />
        </div>
        <div class="contact-card-content">
          <h4>Teléfono</h4>
          <p>+57 123 456 7890</p>
        </div>
      </div>

      <div class="contact-card">
        <div class="icon-wrapper">
          <img src={emailIcon.src} alt="Email icon" />
        </div>
        <div class="contact-card-content">
          <h4>Email</h4>
          <p>info@ezsolutions.co</p>
        </div>
      </div>

    </div>

    <div class="contact-form-wrapper">
      <form class="contact-form">

        <div class="form-row">
          <div class="form-group">
            <label for="name">Nombre</label>
            <input id="name" name="name" type="text" placeholder="Tu nombre" />
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="tu@email.com" />
          </div>
        </div>

        <div class="form-group">
          <label for="message">Mensaje</label>
          <textarea id="message" name="message" placeholder="Cuéntanos sobre tu proyecto"></textarea>
        </div>

        <button type="submit" class="submit-button">
          Enviar Mensaje
        </button>

      </form>
    </div>

  </div>

  <div class="contact-decoration">
    <img src={hexagonIcon.src} class="hex hex-1co" alt="" />
  </div>

</section>
