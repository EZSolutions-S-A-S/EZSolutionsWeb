---
import locationIcon from './icons_contact/location.svg';
import phoneIcon from './icons_contact/phone.svg';
import emailIcon from './icons_contact/email.svg';
import hexagonIcon from '../../assets/icons/hexagon.svg';
---

<section class="contact-section">
  <div class="contact-container">

    <div class="contact-badge" data-i18n-key="contact.badge">
      Contacto
    </div>

    <h2 class="contact-title">
      <span data-i18n-key="contact.title">¿Listo para</span>
      <span class="text-primary" data-i18n-key="contact.titleHighlight">Empezar tu Proyecto?</span>
    </h2>

    <p class="contact-description" data-i18n-key="contact.description">
      Cuéntanos sobre tu idea y te ayudaremos a convertirla en realidad. ¡Estamos aquí para ayudarte!
    </p>

    <div class="contact-info-grid">

      <div class="contact-card">
        <div class="icon-wrapper">
          <img src={locationIcon.src} alt="Location icon" />
        </div>
        <div class="contact-card-content">
          <h4 data-i18n-key="contact.locationTitle">Ubicación</h4>
          <p>Quindío, Colombia</p>
        </div>
      </div>

      <div class="contact-card">
        <div class="icon-wrapper">
          <img src={phoneIcon.src} alt="Phone icon" />
        </div>
        <div class="contact-card-content">
<<<<<<< HEAD
          <h4 data-i18n-key="contact.phoneTitle">Teléfono</h4>
=======
          <h4>Teléfono</h4>
>>>>>>> translations_fix
          <p>+57 316 406 6163</p>
        </div>
      </div>

      <div class="contact-card">
        <div class="icon-wrapper">
          <img src={emailIcon.src} alt="Email icon" />
        </div>
        <div class="contact-card-content">
<<<<<<< HEAD
          <h4 data-i18n-key="contact.emailTitle">Email</h4>
=======
          <h4>Email</h4>
>>>>>>> translations_fix
          <p>ezsolutionssas@gmail.com</p>
        </div>
      </div>

    </div>

    <div class="contact-form-wrapper">
      <form class="contact-form">

        <div class="form-row">
          <div class="form-group">
            <label for="name" data-i18n-key="contact.formName">Nombre</label>
            <input 
              id="name" 
              name="name" 
              type="text" 
              placeholder="Tu nombre"
              data-i18n-attr='{"placeholder":"contact.formNamePlaceholder"}'
            />
          </div>

          <div class="form-group">
            <label for="email" data-i18n-key="contact.formEmail">Email</label>
            <input 
              id="email" 
              name="email" 
              type="email" 
              placeholder="tu@email.com"
              data-i18n-attr='{"placeholder":"contact.formEmailPlaceholder"}'
            />
          </div>
        </div>

        <div class="form-group">
          <label for="message" data-i18n-key="contact.formMessage">Mensaje</label>
          <textarea 
            id="message" 
            name="message" 
            placeholder="Cuéntanos sobre tu proyecto"
            data-i18n-attr='{"placeholder":"contact.formMessagePlaceholder"}'
          ></textarea>
        </div>

        <button type="submit" class="submit-button" data-i18n-key="contact.formButton">
          Enviar Mensaje
        </button>

      </form>
    </div>

  </div>

  <div class="contact-decoration">
    <img src={hexagonIcon.src} class="hex hex-1co" alt="" />
  </div>

</section>