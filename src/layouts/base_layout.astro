---
import Header from '../components/header/header.astro';
import Footer from '../components/footer/footer.astro';
import PrivacyModal from '../components/footer/modals/privacy_modal.astro';
import TermsModal from '../components/footer/modals/terms_modal.astro';
import QuoteModal from '../components/header/modal/quote_modal.astro';
import '../styles/global.css';

const { title = "EZSolutions", currentPage } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <title>{title}</title>
  </head>

  <body>
    <Header currentPage={currentPage} />

    <main>
      <slot />
    </main>

    <Footer />
    <PrivacyModal />
    <TermsModal />
    <QuoteModal />
  </body>
</html>
